# Copy this to .env and fill in your values
# NEVER commit .env to Git — it's already in .gitignore

# Server
PORT=3001
NODE_ENV=development

# JWT — generate a strong random string, e.g. run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=Aum3136Pandya

# SQLite — path to your database file
# Locally: ./data/cafe.db
# On Railway: use the persistent volume mount path e.g. /data/cafe.db
DB_PATH=./data/cafe.db

# Cloudinary — get these from cloudinary.com dashboard (free tier is enough)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# CORS — comma-separated list of allowed frontend origins
# Locally: http://localhost:5173
# Production: your Vercel URL
CORS_ORIGINS=http://localhost:5173

# Resend Mail Sending - Get a free API Key at https://resend.com
# If this is blank/placeholder, the backend will bypass Resend API calls and print reset links to the server console instead.
RESEND_API_KEY=your_resend_api_key

# Frontend URL (For Password Reset email links)
# Defaults to the first URL in CORS_ORIGINS if not set here
FRONTEND_URL=http://localhost:5173
